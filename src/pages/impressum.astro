---
import Base from '../layouts/Base.astro';
import { contact } from '../data/site.js';
const year = new Date().getFullYear();
---

<Base title="Impressum · Hausmeisterservice Rico Naumann" description="Impressum des Hausmeisterservice Rico Naumann, Lichtenau (Sachsen)." bg="#EEEEF0">
  <div style="min-height:100vh; display:flex; flex-direction:column;">
    <header style="background:#fff; box-shadow:0 4px 20px -14px rgba(12,43,64,.3);">
      <div style="max-width:880px; margin:0 auto; padding:16px 28px; display:flex; align-items:center; justify-content:space-between; gap:16px;">
        <a href="/" style="display:flex; align-items:center; gap:12px;">
          <img src="/bilder/logo.png" alt="Logo Hausmeisterservice Rico Naumann" style="height:46px;" />
          <span style="font-family:'Sora',sans-serif; font-weight:700; font-size:16px; color:#0C2B40; line-height:1.15;">Hausmeisterservice<br /><span style="font-weight:500; font-size:13px; color:#1594CB;">Rico Naumann</span></span>
        </a>
        <a href="/" style="font-weight:600; font-size:14px; color:#216CB4;">← Zur Startseite</a>
      </div>
    </header>

    <main style="flex:1; max-width:880px; width:100%; margin:0 auto; padding:56px 28px 80px;">
      <p style="font-family:'Sora',sans-serif; font-weight:600; font-size:13px; letter-spacing:.2em; text-transform:uppercase; color:#1594CB; margin-bottom:12px;">Rechtliches</p>
      <h1 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(32px,5vw,46px); color:#0C2B40; letter-spacing:-.02em;">Impressum</h1>
      <p style="margin-top:14px; font-size:15px; color:#516577;">Angaben gemäß § 5 Digitale-Dienste-Gesetz (DDG) und § 18 Medienstaatsvertrag (MStV)</p>

      <div style="margin-top:36px; background:#fff; border-radius:20px; padding:38px 40px; box-shadow:0 20px 50px -34px rgba(12,43,64,.5); display:flex; flex-direction:column; gap:30px;">
        <div>
          <h2 style="font-family:'Sora',sans-serif; font-weight:700; font-size:18px; color:#216CB4; margin-bottom:10px;">Hausmeisterservice Rico Naumann</h2>
          <p style="font-size:15.5px; line-height:1.75; color:#3f5466;">Inhaber: Rico Naumann<br />Untere Hauptstraße 93<br />09244 Lichtenau (Sachsen)<br />Deutschland</p>
        </div>
        <div style="height:1px; background:#EEEEF0;"></div>
        <div>
          <h2 style="font-family:'Sora',sans-serif; font-weight:700; font-size:18px; color:#216CB4; margin-bottom:10px;">Kontakt</h2>
          <p style="font-size:15.5px; line-height:1.85; color:#3f5466;">Telefon: <a href={contact.telefonHref} style="color:#216CB4;">{contact.telefon}</a><br />Mobil: <a href={contact.mobilHref} style="color:#216CB4;">{contact.mobil}</a><br />E-Mail: <a href={contact.emailHref} style="color:#216CB4;">{contact.email}</a><br />Web: <a href={contact.webHref} style="color:#216CB4;">{contact.web}</a></p>
        </div>
        <div style="height:1px; background:#EEEEF0;"></div>
        <div>
          <h2 style="font-family:'Sora',sans-serif; font-weight:700; font-size:18px; color:#216CB4; margin-bottom:10px;">Umsatzsteuer-Identifikationsnummer</h2>
          <p style="font-size:15.5px; line-height:1.75; color:#3f5466;">gemäß § 27a Umsatzsteuergesetz: 222/252/03362</p>
        </div>
        <div style="height:1px; background:#EEEEF0;"></div>
        <div>
          <h2 style="font-family:'Sora',sans-serif; font-weight:700; font-size:18px; color:#216CB4; margin-bottom:10px;">Berufshaftpflichtversicherung</h2>
          <p style="font-size:15.5px; line-height:1.75; color:#3f5466;">Versicherer: Württembergische Versicherung AG<br />Räumlicher Geltungsbereich: Deutschland<br />VS-Nr: 11-1079958-20</p>
        </div>
        <div style="height:1px; background:#EEEEF0;"></div>
        <div>
          <h2 style="font-family:'Sora',sans-serif; font-weight:700; font-size:18px; color:#216CB4; margin-bottom:10px;">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
          <p style="font-size:15.5px; line-height:1.75; color:#3f5466;">Rico Naumann, Anschrift wie oben.</p>
        </div>
        <div style="height:1px; background:#EEEEF0;"></div>
        <div>
          <h2 style="font-family:'Sora',sans-serif; font-weight:700; font-size:18px; color:#216CB4; margin-bottom:10px;">Verbraucherstreitbeilegung / Universalschlichtungsstelle</h2>
          <p style="font-size:15.5px; line-height:1.75; color:#3f5466;">Wir sind nicht bereit und nicht verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>
        </div>
      </div>
    </main>

    <footer style="background:#0C2B40; color:#9fb4c6;">
      <div style="max-width:880px; margin:0 auto; padding:24px 28px; display:flex; flex-wrap:wrap; gap:12px; justify-content:space-between; align-items:center;">
        <p style="font-size:13px;">© {year} Hausmeisterservice Rico Naumann</p>
        <div style="display:flex; gap:20px;">
          <a href="/" style="font-size:13px; color:#9fd3ec;">Startseite</a>
          <a href="/datenschutz" style="font-size:13px; color:#9fd3ec;">Datenschutz</a>
        </div>
      </div>
    </footer>
  </div>
</Base>
