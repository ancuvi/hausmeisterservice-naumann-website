---
import Base from '../layouts/Base.astro';
import { contact } from '../data/site.js';
const year = new Date().getFullYear();
---

<Base title="Datenschutz · Hausmeisterservice Rico Naumann" description="Datenschutzerklärung des Hausmeisterservice Rico Naumann." bg="#EEEEF0">
  <div style="min-height:100vh; display:flex; flex-direction:column;">
    <header style="background:#fff; box-shadow:0 4px 20px -14px rgba(12,43,64,.3);">
      <div style="max-width:880px; margin:0 auto; padding:16px 28px; display:flex; align-items:center; justify-content:space-between; gap:16px;">
        <a href="/" style="display:flex; align-items:center; gap:12px;">
          <img src="/bilder/logo.png" alt="Logo Hausmeisterservice Rico Naumann" style="height:46px;" />
          <span style="font-family:'Sora',sans-serif; font-weight:700; font-size:16px; color:#0C2B40; line-height:1.15;">Hausmeisterservice<br /><span style="font-weight:500; font-size:13px; color:#1594CB;">Rico Naumann</span></span>
        </a>
        <a href="/" style="font-weight:600; font-size:14px; color:#216CB4;">← Zur Startseite</a>
      </div>
    </header>

    <main style="flex:1; max-width:880px; width:100%; margin:0 auto; padding:56px 28px 80px;">
      <p style="font-family:'Sora',sans-serif; font-weight:600; font-size:13px; letter-spacing:.2em; text-transform:uppercase; color:#1594CB; margin-bottom:12px;">Rechtliches</p>
      <h1 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(32px,5vw,46px); color:#0C2B40; letter-spacing:-.02em;">Datenschutzerklärung</h1>

      <div style="margin-top:36px; background:#fff; border-radius:20px; padding:48px 40px; box-shadow:0 20px 50px -34px rgba(12,43,64,.5); text-align:center;">
        <div style="width:74px; height:74px; margin:0 auto 22px; border-radius:20px; background:linear-gradient(135deg,#216CB4,#1594CB); display:flex; align-items:center; justify-content:center; font-size:34px;">🔒</div>
        <h2 style="font-family:'Sora',sans-serif; font-weight:700; font-size:22px; color:#0C2B40;">Inhalt folgt</h2>
        <p style="margin-top:14px; font-size:15.5px; line-height:1.75; color:#516577; max-width:520px; margin-left:auto; margin-right:auto;">Die vollständige Datenschutzerklärung wird in Kürze ergänzt (Erstellung über eRecht24). Bei Fragen zum Datenschutz erreichen Sie uns jederzeit über die unten stehenden Kontaktdaten.</p>
        <div style="margin-top:28px; display:inline-flex; flex-direction:column; gap:6px; background:#F4F9FE; border:1px solid #E1F3FF; border-radius:16px; padding:20px 28px;">
          <p style="font-family:'Sora',sans-serif; font-weight:700; font-size:15px; color:#0C2B40;">Hausmeisterservice Rico Naumann</p>
          <a href={contact.telefonHref} style="font-size:14.5px; color:#216CB4;">{contact.telefon}</a>
          <a href={contact.emailHref} style="font-size:14.5px; color:#216CB4;">{contact.email}</a>
        </div>
      </div>
    </main>

    <footer style="background:#0C2B40; color:#9fb4c6;">
      <div style="max-width:880px; margin:0 auto; padding:24px 28px; display:flex; flex-wrap:wrap; gap:12px; justify-content:space-between; align-items:center;">
        <p style="font-size:13px;">© {year} Hausmeisterservice Rico Naumann</p>
        <div style="display:flex; gap:20px;">
          <a href="/" style="font-size:13px; color:#9fd3ec;">Startseite</a>
          <a href="/impressum" style="font-size:13px; color:#9fd3ec;">Impressum</a>
        </div>
      </div>
    </footer>
  </div>
</Base>
