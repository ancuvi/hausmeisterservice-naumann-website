---
import Base from '../layouts/Base.astro';
import { services, milestones, testimonials, contact } from '../data/site.js';
const year = new Date().getFullYear();
---

<Base>
  <div style="position:relative; width:100%;">

    <!-- ===== HEADER ===== -->
    <header id="hdr" class="hdr" style="position:fixed; top:0; left:0; right:0; z-index:100; padding:18px 0;">
      <div style="max-width:1200px; margin:0 auto; padding:0 28px; display:flex; align-items:center; justify-content:space-between; gap:20px;">
        <a href="#top" style="display:flex; align-items:center; gap:13px;">
          <img class="hdr-logo" src="/bilder/logo.png" alt="Logo Hausmeisterservice Rico Naumann" style="height:54px; width:auto; transition:height .35s ease; filter:drop-shadow(0 3px 8px rgba(12,43,64,.25));" />
          <span class="hdr-name" style="font-family:'Sora',sans-serif; font-weight:700; font-size:18px; line-height:1.1; color:#fff; text-shadow:0 1px 12px rgba(12,43,64,.45);">Hausmeisterservice<br /><span style="font-weight:500; font-size:14px; color:#1594CB;">Rico Naumann</span></span>
        </a>
        <nav class="hdr-nav" style="display:flex; align-items:center; gap:30px;">
          <a class="navlink" href="#leistungen" style="font-weight:600; font-size:15px; color:#fff; text-shadow:0 1px 10px rgba(12,43,64,.4);">Leistungen</a>
          <a class="navlink" href="#ueber" style="font-weight:600; font-size:15px; color:#fff; text-shadow:0 1px 10px rgba(12,43,64,.4);">Über uns</a>
          <a class="navlink" href="#einsatzgebiet" style="font-weight:600; font-size:15px; color:#fff; text-shadow:0 1px 10px rgba(12,43,64,.4);">Einsatzgebiet</a>
          <a class="navlink" href="#erfahrung" style="font-weight:600; font-size:15px; color:#fff; text-shadow:0 1px 10px rgba(12,43,64,.4);">Erfahrung</a>
        </nav>
        <a class="hdr-cta btn-primary" href="#kontakt" style="background:linear-gradient(135deg,#216CB4,#1594CB); color:#fff; font-weight:700; font-size:14px; padding:12px 22px; border-radius:999px; box-shadow:0 8px 22px -8px rgba(33,108,180,.6);">Kontakt</a>
        <button id="burger" class="burger" aria-label="Menü" aria-expanded="false" style="display:none; flex-direction:column; gap:5px; background:transparent; border:none; cursor:pointer; padding:6px;">
          <span style="display:block; width:26px; height:2.5px; background:#fff; border-radius:2px;"></span>
          <span style="display:block; width:26px; height:2.5px; background:#fff; border-radius:2px;"></span>
          <span style="display:block; width:26px; height:2.5px; background:#fff; border-radius:2px;"></span>
        </button>
      </div>
      <div id="mobnav" class="mobnav" style="background:rgba(255,255,255,.97); backdrop-filter:blur(14px); box-shadow:0 12px 30px -12px rgba(12,43,64,.3);">
        <div style="display:flex; flex-direction:column; padding:8px 28px 18px;">
          <a class="mobitem" href="#leistungen" style="padding:13px 0; font-weight:600; color:#0C2B40; border-bottom:1px solid #EEEEF0;">Leistungen</a>
          <a class="mobitem" href="#ueber" style="padding:13px 0; font-weight:600; color:#0C2B40; border-bottom:1px solid #EEEEF0;">Über uns</a>
          <a class="mobitem" href="#einsatzgebiet" style="padding:13px 0; font-weight:600; color:#0C2B40; border-bottom:1px solid #EEEEF0;">Einsatzgebiet</a>
          <a class="mobitem" href="#erfahrung" style="padding:13px 0; font-weight:600; color:#0C2B40; border-bottom:1px solid #EEEEF0;">Erfahrung</a>
          <a class="mobitem" href="#kontakt" style="margin-top:14px; text-align:center; background:linear-gradient(135deg,#216CB4,#1594CB); color:#fff; font-weight:700; padding:13px; border-radius:999px;">Kontakt aufnehmen</a>
        </div>
      </div>
    </header>

    <!-- ===== HERO ===== -->
    <section id="top" style="position:relative; min-height:100vh; display:flex; align-items:center; overflow:hidden;">
      <div style="position:absolute; inset:0; overflow:hidden;">
        <img class="kb" src="/bilder/hero-haus.webp" alt="Einfamilienhaus mit Firmen-Transporter von Hausmeisterservice Rico Naumann" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 38%; animation:kb 22s ease-in-out infinite alternate;" />
      </div>
      <div style="position:absolute; inset:0; background:linear-gradient(105deg, rgba(12,43,64,.92) 0%, rgba(20,70,120,.78) 38%, rgba(12,43,64,.30) 72%, rgba(12,43,64,.12) 100%);"></div>
      <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(12,43,64,.55), transparent 40%);"></div>

      <div style="position:relative; z-index:2; max-width:1200px; width:100%; margin:0 auto; padding:130px 28px 90px;">
        <div style="max-width:680px;">
          <div class="reveal" style="display:inline-flex; align-items:center; gap:10px; background:rgba(21,148,203,.18); border:1px solid rgba(225,243,255,.35); backdrop-filter:blur(6px); padding:8px 16px 8px 10px; border-radius:999px; margin-bottom:26px;">
            <img src="/bilder/logo.png" alt="" style="height:30px; width:auto;" />
            <span style="font-family:'Sora',sans-serif; font-weight:600; font-size:12.5px; letter-spacing:.14em; color:#E1F3FF; text-transform:uppercase;">Est. 2025 · Raum Chemnitz</span>
          </div>
          <h1 class="reveal hero-h1" style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(29px,7vw,68px); line-height:1.04; color:#fff; letter-spacing:-.02em; text-shadow:0 4px 30px rgba(12,43,64,.4);">Zuverlässiger<br />Hausmeisterservice<br /><span style="background:linear-gradient(120deg,#E1F3FF,#1594CB); -webkit-background-clip:text; background-clip:text; color:transparent;">für Ihr Objekt</span></h1>
          <p class="reveal" style="margin-top:24px; font-family:'Sora',sans-serif; font-weight:600; font-size:clamp(18px,2.4vw,24px); color:#E1F3FF; letter-spacing:.01em;">Kompetent. <span style="color:#fff;">Schnell.</span> Persönlich.</p>
          <p class="reveal" style="margin-top:16px; font-size:17px; line-height:1.6; color:rgba(225,243,255,.85); max-width:520px;">Rundum-sorglos-Betreuung für private und gewerbliche Immobilien – mit festem persönlichem Ansprechpartner und transparenten Preisen.</p>
          <div class="reveal" style="margin-top:38px; display:flex; flex-wrap:wrap; align-items:center; gap:18px;">
            <a class="btn-primary pulsecta" href="#kontakt" style="background:linear-gradient(135deg,#216CB4,#1594CB); color:#fff; font-family:'Sora',sans-serif; font-weight:700; font-size:16px; padding:17px 34px; border-radius:999px; animation:pulse 3.2s ease-in-out infinite;">Kostenlose Beratung vereinbaren</a>
            <a class="btn-ghost" href="#leistungen" style="border:1.5px solid rgba(225,243,255,.6); color:#fff; font-family:'Sora',sans-serif; font-weight:600; font-size:15px; padding:16px 28px; border-radius:999px;">Unsere Leistungen</a>
          </div>
        </div>
      </div>
      <a href="#leistungen" class="floaty" style="position:absolute; left:50%; bottom:26px; transform:translateX(-50%); z-index:2; display:flex; flex-direction:column; align-items:center; gap:8px; animation:floaty 2.6s ease-in-out infinite;">
        <span style="font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:rgba(225,243,255,.75);">Scrollen</span>
        <span style="display:block; width:1px; height:38px; background:linear-gradient(to bottom, rgba(225,243,255,.8), transparent);"></span>
      </a>
    </section>

    <!-- ===== TRUST STRIP ===== -->
    <div style="background:#0C2B40; color:#fff;">
      <div style="max-width:1200px; margin:0 auto; padding:28px; display:flex; flex-wrap:wrap; justify-content:space-between; gap:24px;">
        <div class="reveal" style="display:flex; align-items:center; gap:14px;">
          <span style="font-family:'Sora',sans-serif; font-weight:800; font-size:34px; color:#1594CB;">10+</span>
          <span style="font-size:14px; line-height:1.35; color:#cfe3f3;">Jahre Erfahrung in der<br />Objektbetreuung</span>
        </div>
        <div class="reveal" style="display:flex; align-items:center; gap:14px;">
          <span style="font-family:'Sora',sans-serif; font-weight:800; font-size:34px; color:#1594CB;">6</span>
          <span style="font-size:14px; line-height:1.35; color:#cfe3f3;">Leistungen aus<br />einer Hand</span>
        </div>
        <div class="reveal" style="display:flex; align-items:center; gap:14px;">
          <span style="font-family:'Sora',sans-serif; font-weight:800; font-size:34px; color:#1594CB;">1:1</span>
          <span style="font-size:14px; line-height:1.35; color:#cfe3f3;">Fester persönlicher<br />Ansprechpartner</span>
        </div>
        <div class="reveal" style="display:flex; align-items:center; gap:14px;">
          <span style="font-family:'Sora',sans-serif; font-weight:800; font-size:34px; color:#1594CB;">0 €</span>
          <span style="font-size:14px; line-height:1.35; color:#cfe3f3;">Beratung –<br />unverbindlich & fair</span>
        </div>
      </div>
    </div>

    <!-- ===== LEISTUNGEN ===== -->
    <section id="leistungen" style="position:relative; background:linear-gradient(165deg,#0C2B40 0%,#143a5c 55%,#216CB4 130%); padding:104px 0 110px;">
      <div style="max-width:1200px; margin:0 auto; padding:0 28px;">
        <div style="max-width:640px; margin-bottom:54px;">
          <p class="reveal" style="font-family:'Sora',sans-serif; font-weight:600; font-size:13px; letter-spacing:.22em; text-transform:uppercase; color:#1594CB; margin-bottom:14px;">Was wir für Sie tun</p>
          <h2 class="reveal" style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(30px,4.4vw,46px); color:#fff; line-height:1.08; letter-spacing:-.02em;">Leistungen</h2>
          <p class="reveal" style="margin-top:18px; font-size:17px; line-height:1.6; color:rgba(225,243,255,.8);">Alles rund um Ihre Immobilie – sauber, sicher und werterhaltend. Sechs Kernleistungen, die wir flexibel an Ihren Bedarf anpassen.</p>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(290px,1fr)); gap:26px;">
          {services.map((s) => (
            <div class="svc reveal" style="background:#fff; border-radius:20px; overflow:hidden; box-shadow:0 18px 40px -28px rgba(0,0,0,.5);">
              <div style="position:relative; height:188px; overflow:hidden;">
                <img class="grow" src={s.img} alt={s.alt} style="width:100%; height:100%; object-fit:cover; display:block;" />
                <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(12,43,64,.35), transparent 55%);"></div>
                <span style="position:absolute; top:14px; left:14px; background:rgba(255,255,255,.92); color:#216CB4; font-family:'Sora',sans-serif; font-weight:700; font-size:13px; width:30px; height:30px; border-radius:9px; display:flex; align-items:center; justify-content:center;">{s.no}</span>
              </div>
              <div style="padding:24px 24px 28px;">
                <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:20px; color:#0C2B40;">{s.title}</h3>
                <div class="accent" style="width:38px; height:3px; border-radius:3px; background:linear-gradient(90deg,#216CB4,#1594CB); margin:13px 0 15px; transition:width .45s ease;"></div>
                <p style="font-size:14.5px; line-height:1.62; color:#516577;">{s.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== ÜBER UNS ===== -->
    <section id="ueber" style="background:#fff; padding:104px 0;">
      <div style="max-width:1200px; margin:0 auto; padding:0 28px; display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:60px; align-items:center;">
        <div class="reveal" style="position:relative;">
          <div style="position:absolute; top:-22px; left:-22px; width:120px; height:120px; border-radius:24px; background:#E1F3FF; z-index:0;"></div>
          <div style="position:absolute; bottom:-22px; right:-22px; width:90px; height:90px; border-radius:50%; background:linear-gradient(135deg,#216CB4,#1594CB); opacity:.18; z-index:0;"></div>
          <img src="/bilder/ueber-uns-fassade.png" alt="Moderne weiße Hausfassade mit Eingangstür" style="position:relative; z-index:1; width:100%; border-radius:22px; box-shadow:0 30px 60px -30px rgba(12,43,64,.5); display:block;" />
          <div style="position:absolute; z-index:2; bottom:24px; left:24px; background:rgba(255,255,255,.95); backdrop-filter:blur(8px); border-radius:16px; padding:16px 20px; box-shadow:0 16px 30px -16px rgba(12,43,64,.4); display:flex; align-items:center; gap:13px;">
            <img src="/bilder/logo.png" alt="" style="height:42px;" />
            <div>
              <p style="font-family:'Sora',sans-serif; font-weight:700; font-size:15px; color:#0C2B40; line-height:1.1;">Rico Naumann</p>
              <p style="font-size:12.5px; color:#1594CB; font-weight:600;">Ihr Ansprechpartner</p>
            </div>
          </div>
        </div>
        <div>
          <p class="reveal" style="font-family:'Sora',sans-serif; font-weight:600; font-size:13px; letter-spacing:.22em; text-transform:uppercase; color:#1594CB; margin-bottom:14px;">Wer wir sind</p>
          <h2 class="reveal" style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(30px,4.4vw,46px); color:#0C2B40; line-height:1.08; letter-spacing:-.02em;">Über uns</h2>
          <p class="reveal" style="margin-top:22px; font-size:17px; line-height:1.72; color:#3f5466;">Wir sind ein regionaler Hausmeisterservice mit über zehn Jahren Erfahrung in der ganzheitlichen Objektbetreuung. Private Hauseigentümer, WEG-Verwalter und Gewerbekunden schätzen unsere All-in-One-Leistungen: von regelmäßigen Objektkontrollen über Gartenpflege bis hin zu kleinen Reparaturen und Glühbirnenwechseln.</p>
          <p class="reveal" style="margin-top:16px; font-size:17px; line-height:1.72; color:#3f5466;">Dabei legen wir großen Wert auf transparente Preise ohne versteckte Kosten. Mit einem festen persönlichen Ansprechpartner garantieren wir kurze Kommunikationswege und individuellen Service.</p>
          <div class="reveal" style="margin-top:30px; display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:14px;">
            {['Transparente Preise', 'Kurze Wege', 'All-in-One Service', 'Privat & Gewerbe'].map((f) => (
              <div style="display:flex; align-items:center; gap:12px; background:#F4F9FE; border:1px solid #E1F3FF; border-radius:14px; padding:14px 16px;">
                <span style="flex:none; width:34px; height:34px; border-radius:9px; background:linear-gradient(135deg,#216CB4,#1594CB); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800;">✓</span>
                <span style="font-weight:600; font-size:14.5px; color:#0C2B40;">{f}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== EINSATZGEBIET ===== -->
    <section id="einsatzgebiet" style="position:relative; background:#EEEEF0; padding:104px 0; overflow:hidden;">
      <div style="max-width:1200px; margin:0 auto; padding:0 28px; display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:56px; align-items:center;">
        <div>
          <p class="reveal" style="font-family:'Sora',sans-serif; font-weight:600; font-size:13px; letter-spacing:.22em; text-transform:uppercase; color:#1594CB; margin-bottom:14px;">Wo wir für Sie da sind</p>
          <h2 class="reveal" style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(30px,4.4vw,46px); color:#0C2B40; line-height:1.08; letter-spacing:-.02em;">Unser Einsatzgebiet</h2>
          <p class="reveal" style="margin-top:22px; font-size:17px; line-height:1.72; color:#3f5466;">Unser Einsatzgebiet umfasst das Stadtgebiet Chemnitz und Umgebung. Wir bieten privaten und gewerblichen Kunden einen umfassenden Hausmeisterservice: Reparaturen, Gartenpflege, Treppenhausreinigung, Winterdienst und Kleintransporte.</p>
          <p class="reveal" style="margin-top:16px; font-size:17px; line-height:1.72; color:#3f5466;">Mit flexiblen Servicezeiten stehen wir Ihnen persönlich zur Seite. Verlassen Sie sich auf unser erfahrenes Team, das zuverlässig für Ordnung, Sicherheit und Werterhalt sorgt – ob Wohnhaus, Bürogebäude oder Gewerbefläche.</p>
          <div class="reveal" style="margin-top:28px; display:flex; flex-wrap:wrap; gap:10px;">
            {['Chemnitz', 'Lichtenau', 'Niederlichtenau', '+ Umgebung'].map((o) => (
              <span style="background:#fff; border:1px solid #d9e6f2; color:#216CB4; font-weight:600; font-size:14px; padding:9px 18px; border-radius:999px;">{o}</span>
            ))}
          </div>
        </div>
        <div class="reveal" style="position:relative;">
          <img src="/bilder/einsatzgebiet.png" alt="Einsatzgebiet Chemnitz und Umgebung" style="width:100%; border-radius:22px; box-shadow:0 30px 60px -30px rgba(12,43,64,.45); display:block;" />
          <div style="position:absolute; bottom:20px; left:20px; right:20px; background:rgba(12,43,64,.88); backdrop-filter:blur(8px); border-radius:16px; padding:16px 20px; display:flex; align-items:center; gap:13px;">
            <span class="spinslow" style="flex:none; width:12px; height:12px; border-radius:50%; background:#1594CB; box-shadow:0 0 0 5px rgba(21,148,203,.25);"></span>
            <p style="color:#E1F3FF; font-size:14px; line-height:1.4;"><strong style="color:#fff;">Standort Lichtenau</strong> · Untere Hauptstraße 93 · zentral im Raum Chemnitz</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== ERFAHRUNG / TIMELINE ===== -->
    <section id="erfahrung" style="background:linear-gradient(180deg,#E1F3FF,#f4fbff); padding:104px 0;">
      <div style="max-width:1200px; margin:0 auto; padding:0 28px; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:56px;">
        <div>
          <p class="reveal" style="font-family:'Sora',sans-serif; font-weight:600; font-size:13px; letter-spacing:.22em; text-transform:uppercase; color:#1594CB; margin-bottom:14px;">Unser Weg</p>
          <h2 class="reveal" style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(30px,4.4vw,46px); color:#0C2B40; line-height:1.08; letter-spacing:-.02em;">Erfahrung &amp;<br />Leistungen</h2>
          <p class="reveal" style="margin-top:20px; font-size:17px; line-height:1.7; color:#3f5466; max-width:380px;">Von der Gründung bis zum heutigen Vollservice – wir entwickeln uns stetig weiter, damit Ihre Immobilie in den besten Händen ist.</p>
        </div>
        <div style="position:relative; padding-left:34px;">
          <div style="position:absolute; left:7px; top:6px; bottom:6px; width:2px; background:linear-gradient(to bottom,#1594CB,#216CB4,rgba(33,108,180,.2));"></div>
          {milestones.map((m) => (
            <div class="reveal" style="position:relative; margin-bottom:34px;">
              <span style="position:absolute; left:-34px; top:4px; width:16px; height:16px; border-radius:50%; background:#fff; border:3px solid #1594CB; box-shadow:0 0 0 5px rgba(21,148,203,.14);"></span>
              <div style="background:#fff; border-radius:18px; padding:24px 26px; box-shadow:0 16px 36px -26px rgba(12,43,64,.45);">
                <span style="font-family:'Sora',sans-serif; font-weight:700; font-size:12px; letter-spacing:.12em; text-transform:uppercase; color:#1594CB;">{m.tag}</span>
                <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:19px; color:#0C2B40; margin:8px 0 14px; line-height:1.25;">{m.title}</h3>
                <ul style="list-style:none; display:flex; flex-direction:column; gap:9px;">
                  {m.points.map((p) => (
                    <li style="display:flex; gap:11px; font-size:14.5px; line-height:1.55; color:#516577;">
                      <span style="flex:none; margin-top:7px; width:6px; height:6px; border-radius:50%; background:#216CB4;"></span>
                      <span>{p}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== TESTIMONIALS ===== -->
    <section style="position:relative; background:linear-gradient(160deg,#216CB4,#143a5c); padding:104px 0; overflow:hidden;">
      <div style="position:absolute; top:-80px; right:-80px; width:320px; height:320px; border-radius:50%; background:radial-gradient(circle,rgba(21,148,203,.4),transparent 70%);"></div>
      <div style="max-width:1200px; margin:0 auto; padding:0 28px; position:relative;">
        <div style="text-align:center; max-width:620px; margin:0 auto 54px;">
          <p class="reveal" style="font-family:'Sora',sans-serif; font-weight:600; font-size:13px; letter-spacing:.22em; text-transform:uppercase; color:#9fd3ec; margin-bottom:14px;">Stimmen unserer Kunden</p>
          <h2 class="reveal" style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(30px,4.4vw,46px); color:#fff; line-height:1.08; letter-spacing:-.02em;">Was unsere Kunden sagen</h2>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(290px,1fr)); gap:26px; align-items:start;">
          {testimonials.map((t) => (
            <div class="reveal" style="background:#fff; border-radius:22px; padding:32px 30px; box-shadow:0 24px 50px -30px rgba(0,0,0,.6);">
              <div style="display:flex; gap:3px; margin-bottom:16px;">
                {Array.from({ length: t.stars }).map(() => (
                  <span style="color:#1594CB; font-size:18px;">★</span>
                ))}
              </div>
              <p style="font-size:15.5px; line-height:1.7; color:#3f5466;">{t.quote}</p>
              <div style="margin-top:24px; display:flex; align-items:center; gap:13px;">
                <span style="flex:none; width:46px; height:46px; border-radius:50%; background:linear-gradient(135deg,#216CB4,#1594CB); color:#fff; display:flex; align-items:center; justify-content:center; font-family:'Sora',sans-serif; font-weight:700; font-size:17px;">{t.initials}</span>
                <div>
                  <p style="font-family:'Sora',sans-serif; font-weight:700; font-size:15.5px; color:#0C2B40;">{t.name}</p>
                  <p style="font-size:13px; color:#1594CB; font-weight:600;">{t.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== KONTAKT ===== -->
    <section id="kontakt" style="position:relative; overflow:hidden;">
